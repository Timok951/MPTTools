COMPOSE_PROJECT_NAME=mpt_tools

POSTGRES_PASSWORD=1
POSTGRES_DB=mpttools
DATABASE_NAME=mpttools

MPTTOOLS_WEB_PORT=18080
MPTTOOLS_SMTP_PORT=10225
MPTTOOLS_MAILPIT_UI_PORT=18025
MPTTOOLS_PROMETHEUS_PORT=19176
MPTTOOLS_GRAFANA_PORT=13816
GRAFANA_ROOT_URL=http://localhost:13816
CSRF_TRUSTED_ORIGINS=http://localhost:18080,http://127.0.0.1:18080

DEBUG=true
ALLOWED_HOSTS=localhost,127.0.0.1,web,djangoapp,*

DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@example.com
DJANGO_SUPERUSER_PASSWORD=admin123

EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=mailpit
EMAIL_PORT=1025
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=false
EMAIL_USE_SSL=false
DEFAULT_FROM_EMAIL=noreply@mpt-tools.local

RUN_TESTS_ON_START=false
RUN_DJANGO_CHECK_ON_START=false
AUTO_REFRESH_QUALITY_REPORT_ON_START=false

BACKUP_INTERVAL_SECONDS=86400
