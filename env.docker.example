# Скопируйте в .env рядом с docker-compose.yml.
# Сайт по умолчанию: http://localhost:18080 (не 8000 — меньше конфликтов со вторым приложением).

# --- Стек 1 (пример) ---
COMPOSE_PROJECT_NAME=mpt_tools
POSTGRES_PASSWORD=changeme

MPTTOOLS_WEB_PORT=18080
MPTTOOLS_SMTP_PORT=10225
MPTTOOLS_MAILPIT_UI_PORT=18025
MPTTOOLS_PROMETHEUS_PORT=19176
MPTTOOLS_GRAFANA_PORT=13816
GRAFANA_ROOT_URL=http://localhost:13816

CSRF_TRUSTED_ORIGINS=http://localhost:18080,http://127.0.0.1:18080

# --- Стек 2 (второй клон репозитория — свой .env в той папке) ---
# COMPOSE_PROJECT_NAME=mpt_tools_b
# MPTTOOLS_WEB_PORT=18081
# MPTTOOLS_SMTP_PORT=10226
# MPTTOOLS_MAILPIT_UI_PORT=18026
# MPTTOOLS_PROMETHEUS_PORT=19177
# MPTTOOLS_GRAFANA_PORT=13817
# GRAFANA_ROOT_URL=http://localhost:13817
# CSRF_TRUSTED_ORIGINS=http://localhost:18081,http://127.0.0.1:18081

# Старая БД с именем mpttools:
# POSTGRES_DB=mpttools
# DATABASE_NAME=mpttools

BACKUP_INTERVAL_SECONDS=86400
