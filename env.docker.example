# Скопируйте в .env рядом с docker-compose.yml и подправьте.
# Второй параллельный стек: другой -p / COMPOSE_PROJECT_NAME и свободные порты.
# Имя compose-проекта по умолчанию в файле: mpt_tools (тома mpt_tools_postgres_data и т.д.)

# docker compose -p mpt_tools_alt up -d
# POSTGRES_PASSWORD=...
# Старая база с именем mpttools:
# POSTGRES_DB=mpttools
# DATABASE_NAME=mpttools

MPTTOOLS_WEB_PORT=8000
MPTTOOLS_POSTGRES_PORT=5433
MPTTOOLS_SMTP_PORT=1025
MPTTOOLS_MAILPIT_UI_PORT=8025
MPTTOOLS_PROMETHEUS_PORT=9176
MPTTOOLS_GRAFANA_PORT=3816

# Доступ по LAN (пример):
# ALLOWED_HOSTS=localhost,127.0.0.1,web,djangoapp,192.168.0.122,*
# CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000,http://192.168.0.122:8000

BACKUP_INTERVAL_SECONDS=86400
